{
  "name": "tmuxgo-vscode",
  "displayName": "TmuxGo",
  "description": "Manage tmux sessions in VS Code sidebar — based on vscode-tmux-manager",
  "version": "0.1.0",
  "publisher": "tmuxgo",
  "repository": {
    "type": "git",
    "url": "https://github.com/21hbguo/TmuxGo-vscode.git"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onView:tmuxgo_sessions"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "tmuxgo",
          "title": "TmuxGo",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "views": {
      "tmuxgo": [
        {
          "id": "tmuxgo_sessions",
          "name": "Sessions"
        }
      ]
    },
    "commands": [
      {
        "command": "tmuxgo_vscode.attach",
        "title": "Attach to Session",
        "category": "TmuxGo",
        "icon": "$(debug-start)"
      },
      {
        "command": "tmuxgo_vscode.refresh",
        "title": "Refresh Sessions",
        "category": "TmuxGo",
        "icon": {
          "light": "resources/light/refresh.svg",
          "dark": "resources/dark/refresh.svg"
        }
      },
      {
        "command": "tmuxgo_vscode.toggleAutoRefresh",
        "title": "Toggle Auto Refresh",
        "category": "TmuxGo",
        "icon": "$(sync)"
      },
      {
        "command": "tmuxgo_vscode.rename",
        "title": "Rename Session",
        "category": "TmuxGo"
      },
      {
        "command": "tmuxgo_vscode.renameWindow",
        "title": "Rename Window",
        "category": "TmuxGo"
      },
      {
        "command": "tmuxgo_vscode.new",
        "title": "New Tmux Session",
        "category": "TmuxGo",
        "icon": {
          "light": "resources/light/plus.svg",
          "dark": "resources/dark/plus.svg"
        }
      },
      {
        "command": "tmuxgo_vscode.delete",
        "title": "Delete Session",
        "category": "TmuxGo"
      },
      {
        "command": "tmuxgo_vscode.kill-window",
        "title": "Kill Window",
        "category": "TmuxGo"
      },
      {
        "command": "tmuxgo_vscode.newWindow",
        "title": "New Window",
        "category": "TmuxGo"
      },
      {
        "command": "tmuxgo_vscode.splitPaneRight",
        "title": "Split Pane Right",
        "category": "TmuxGo"
      },
      {
        "command": "tmuxgo_vscode.splitPaneDown",
        "title": "Split Pane Down",
        "category": "TmuxGo"
      },
      {
        "command": "tmuxgo_vscode.inline.newWindow",
        "title": "New Window",
        "category": "TmuxGo",
        "icon": {
          "light": "resources/light/plus.svg",
          "dark": "resources/dark/plus.svg"
        }
      },
      {
        "command": "tmuxgo_vscode.inline.splitPane",
        "title": "Split Pane",
        "category": "TmuxGo",
        "icon": {
          "light": "resources/light/plus.svg",
          "dark": "resources/dark/plus.svg"
        }
      },
      {
        "command": "tmuxgo_vscode.kill-pane",
        "title": "Kill Pane",
        "category": "TmuxGo"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "tmuxgo_vscode.new",
          "when": "view == tmuxgo_sessions",
          "group": "navigation"
        },
        {
          "command": "tmuxgo_vscode.refresh",
          "when": "view == tmuxgo_sessions",
          "group": "navigation"
        },
        {
          "command": "tmuxgo_vscode.toggleAutoRefresh",
          "when": "view == tmuxgo_sessions",
          "group": "1_settings"
        }
      ],
      "view/item/context": [
        {
          "command": "tmuxgo_vscode.attach",
          "when": "view == tmuxgo_sessions && (viewItem == tmuxSession || viewItem == tmuxWindow || viewItem == tmuxPane)",
          "group": "inline"
        },
        {
          "command": "tmuxgo_vscode.inline.newWindow",
          "when": "view == tmuxgo_sessions && viewItem == tmuxSession",
          "group": "inline"
        },
        {
          "command": "tmuxgo_vscode.inline.splitPane",
          "when": "view == tmuxgo_sessions && viewItem == tmuxPane",
          "group": "inline"
        },
        {
          "command": "tmuxgo_vscode.rename",
          "when": "view == tmuxgo_sessions && viewItem == tmuxSession",
          "group": "1_modification"
        },
        {
          "command": "tmuxgo_vscode.renameWindow",
          "when": "view == tmuxgo_sessions && viewItem == tmuxWindow",
          "group": "1_modification"
        },
        {
          "command": "tmuxgo_vscode.newWindow",
          "when": "view == tmuxgo_sessions && viewItem == tmuxSession",
          "group": "1_modification"
        },
        {
          "command": "tmuxgo_vscode.splitPaneRight",
          "when": "view == tmuxgo_sessions && viewItem == tmuxPane",
          "group": "1_modification"
        },
        {
          "command": "tmuxgo_vscode.splitPaneDown",
          "when": "view == tmuxgo_sessions && viewItem == tmuxPane",
          "group": "1_modification"
        },
        {
          "command": "tmuxgo_vscode.delete",
          "when": "view == tmuxgo_sessions && viewItem == tmuxSession",
          "group": "2_destructive"
        },
        {
          "command": "tmuxgo_vscode.kill-window",
          "when": "view == tmuxgo_sessions && viewItem == tmuxWindow",
          "group": "2_destructive"
        },
        {
          "command": "tmuxgo_vscode.kill-pane",
          "when": "view == tmuxgo_sessions && viewItem == tmuxPane",
          "group": "2_destructive"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package --allow-missing-repository"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^2.22.0",
    "typescript": "^5.3.0"
  }
}
